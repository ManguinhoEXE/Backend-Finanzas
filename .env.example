# ============================================
# CONFIGURACION DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo como .env y completa los valores
# NUNCA subir el archivo .env a repositorios

# ============================================
# DJANGO
# ============================================
SECRET_KEY=tu-secret-key-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# POSTGRESQL (Desarrollo local)
# ============================================
# Estas variables se usan cuando NO hay DATABASE_URL
DB_NAME=postgres
USER=postgres.tu-proyecto
PASSWORD=tu-password-de-supabase-aqui
HOST=tu-host-de-supabase-aqui
DB_PORT=6543

# ============================================
# DATABASE_URL (Produccion)
# ============================================
# En produccion, configura DATABASE_URL con tu cadena de conexion:
# DATABASE_URL=postgres://postgres.xxx:password@host:5432/dbname?sslmode=require

# ============================================
# JWT
# ============================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# ============================================
# DOCKER (Desarrollo)
# ============================================
# POSTGRES_DB=finanzas_dev
# POSTGRES_USER=finanzas_user
# POSTGRES_PASSWORD=finanzas_pass
