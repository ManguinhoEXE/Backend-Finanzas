# ============================================
# CONFIGURACION DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo como .env y completa los valores
# NUNCA subir el archivo .env a repositorios

# ============================================
# DJANGO
# ============================================
SECRET_KEY=tu-secret-key-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# POSTGRESQL (Supabase — Produccion)
# ============================================
# Obtén estos valores desde Supabase:
# 1. Ve a tu proyecto en Supabase
# 2. Settings > Database > Connection string
# 3. Copia los valores del panel "Connection string" > URI
DB_NAME=postgres
USER=postgres.tu-proyecto
PASSWORD=tu-password-de-supabase-aqui
HOST=aws-1-us-east-2.pooler.supabase.com
PORT=6543

# ============================================
# POSTGRESQL (Docker Local — Desarrollo)
# ============================================
# Estas variables se usan cuando ejecutas docker-compose.yml
# El servicio db de PostgreSQL usa estas valores por defecto
# POSTGRES_DB=finanzas_dev
# POSTGRES_USER=finanzas_user
# POSTGRES_PASSWORD=finanzas_pass

# ============================================
# JWT
# ============================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# ============================================
# RENDER (Produccion)
# ============================================
# Estas variables se configuran en el Dashboard de Render
# SECRET_KEY (auto-generada por Render)
# DEBUG=False
# ALLOWED_HOSTS=.onrender.com
# DB_NAME, USER, PASSWORD, HOST, PORT (valores de Supabase)
